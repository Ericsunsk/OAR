# OAR 后端运行时配置示例。
#
# 本地 cargo run 未设置时默认监听 127.0.0.1:8080。
# Docker compose 会在容器内默认注入 0.0.0.0:8080。
# OAR_HTTP_BIND_ADDR=127.0.0.1:8080

# 不要提交真实飞书应用密钥、授权码、access token 或 refresh token。

# 存储配置。配置 DATABASE_URL 后，后端会启用 OAR session store、受保护路由、
# Review Inbox 与 Agent settings 持久化；飞书扫码成功也会加密落库用户绑定 TokenGrant。
# Docker compose 本地默认使用下面的 Postgres；生产部署必须改为云端/托管 Postgres。
DATABASE_URL=postgres://oar:oar@postgres:5432/oar

# 本地 Postgres 端口映射，宿主机 5432 被占用时可覆盖。
# POSTGRES_PORT=5432

# 飞书 OpenAPI 运行时配置。以下为可选覆盖项，未设置时使用代码内置默认值。
# OAR_FEISHU_BASE_URL=https://open.feishu.cn
# OAR_FEISHU_MAX_RESPONSE_BYTES=65536
# OAR_FEISHU_REQUEST_TIMEOUT_MS=30000
# OAR_FEISHU_CONNECT_TIMEOUT_MS=5000

# 真实飞书 OAuth 登录与 auth refresh adapter 接线时的必填项。
# App ID / App Secret 来自飞书开发者后台应用的“凭证与基础信息”。
# 它们标识 OAR 这个应用/部署，不代表某个用户或机器人；用户扫码后会生成按 tenant_key + open_id 绑定的 TokenGrant。
# 这里只能保留占位值，真实值通过本地 .env、CI secret 或部署平台 secret 注入。
OAR_FEISHU_APP_ID=cli_placeholder
OAR_FEISHU_APP_SECRET=replace_with_secret_manager_value
OAR_FEISHU_REDIRECT_URI=https://oar.example.com/auth/feishu/callback

# 飞书授权页和授权范围使用代码内置默认值：offline_access + OAR 已声明用户级能力所需的 Feishu scopes。
# 先在飞书开发者后台开启对应权限，再让用户用 OAR 重新扫码授权；
# 旧 TokenGrant 不会自动增加新 scope。写操作仍受 dry-run、人工确认、ledger 和 audit 保护。

# OAR Agent 默认模型服务配置。前端不会直连模型 API；
# 后端按 OAR_AGENT_PROVIDER 选择默认协议，并统一转换为 OAR SSE。
# 登录用户也可以在前端设置自己的 baseURL/API key；后端会自动检测协议和模型，
# 并用 OAR_GRANT_KEY_* 加密保存用户级 BYOK API key。
# OAR_AGENT_PROVIDER=openai-compatible
# OAR_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
# OAR_AGENT_OPENAI_API_KEY=replace_with_secret_manager_value
# OAR_AGENT_OPENAI_MODEL=gpt-4.1
#
# 或者切到 Anthropic Messages API：
# OAR_AGENT_PROVIDER=anthropic
# OAR_AGENT_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# OAR_AGENT_ANTHROPIC_API_KEY=replace_with_secret_manager_value
# OAR_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-5
# OAR_AGENT_ANTHROPIC_VERSION=2023-06-01

# 本地开发可打开一次性内存 grant key。生产不要打开；生产必须使用下面的稳定密钥。
# OAR_GRANT_KEY_* 用于加密 Feishu grant 和用户级 BYOK API key；配置 DATABASE_URL 时必填。
# OAR_ALLOW_EPHEMERAL_GRANT_KEY=true
OAR_GRANT_KEY_ID=key-prod-v1
OAR_GRANT_KEY_HEX=64_hex_chars_for_32_byte_aes_key

# 真实 Feishu OAuth refresh smoke，仅用于一次性本地/CI 验证测试授权。
# 它会调用真实 refresh endpoint，并可能轮换/消费提供的 refresh token；不要使用生产用户授权。
# 还需要 DATABASE_URL、OAR_FEISHU_APP_ID、OAR_FEISHU_APP_SECRET 和稳定 OAR_GRANT_KEY_*。
# OAR_TEST_FEISHU_REFRESH_SMOKE_ENABLED=false
# OAR_TEST_FEISHU_REFRESH_TOKEN=replace_with_throwaway_test_refresh_token
# OAR_TEST_FEISHU_REFRESH_SCOPE=

# 租户维护运行时配置。启用后，oar-http-facade 会在成功绑定监听后启动后台 daemon，
# 周期发现 active tenants 并执行 auth refresh scheduled sweep + audit outbox drain；
# 因此默认关闭，不能因为存在数据库或飞书配置而自动启用。
# 启用时必须同时配置 DATABASE_URL、稳定 OAR_GRANT_KEY_*、完整飞书 OAuth app 配置，
# 并显式配置真实 audit outbox sink；noop/local-noop 只能用于测试，不能用于后台 daemon。
# OAR_ALLOW_EPHEMERAL_GRANT_KEY=true 与租户维护运行时互斥。
# OAR_TENANT_MAINTENANCE_ENABLED=false
# OAR_TENANT_MAINTENANCE_INSTANCE_ID=oar-prod-1
# OAR_TENANT_MAINTENANCE_INTERVAL_MS=60000
# OAR_TENANT_MAINTENANCE_DUE_LOOKAHEAD_MS=300000
# OAR_TENANT_MAINTENANCE_AUDIT_OUTBOX_SINK=webhook
# OAR_TENANT_MAINTENANCE_AUDIT_OUTBOX_WEBHOOK_URL=https://audit.example.test/oar

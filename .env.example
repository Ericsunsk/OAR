# OAR backend runtime example.
#
# Local development default. The backend already uses this value when the
# variable is absent, but keeping it here makes the runtime contract explicit.
OAR_HTTP_BIND_ADDR=127.0.0.1:8080

# Docker containers should bind all interfaces. Prefer setting this in
# Dockerfile, docker run, or compose instead of changing the local default.
# OAR_HTTP_BIND_ADDR=0.0.0.0:8080

# Do not commit real Feishu/Lark app secrets, auth codes, access tokens, or
# refresh tokens. Add those env vars only when the real backend auth/storage
# paths are wired.

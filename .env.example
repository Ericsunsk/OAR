# OAR 后端运行时配置示例。
#
# 本地 cargo run 未设置时默认监听 127.0.0.1:8080。
# Docker compose 会在容器内默认注入 0.0.0.0:8080。
# OAR_HTTP_BIND_ADDR=127.0.0.1:8080

# 不要提交真实飞书应用密钥、授权码、access token 或 refresh token。

# 飞书 OpenAPI 运行时配置。以下为可选覆盖项，未设置时使用代码内置默认值。
# OAR_FEISHU_BASE_URL=https://open.feishu.cn
# OAR_FEISHU_MAX_RESPONSE_BYTES=65536
# OAR_FEISHU_REQUEST_TIMEOUT_MS=30000
# OAR_FEISHU_CONNECT_TIMEOUT_MS=5000

# 真实飞书 auth refresh adapter 接线时的必填项。
# 这里只能保留占位值，真实值通过本地 .env、CI secret 或部署平台 secret 注入。
OAR_FEISHU_APP_ID=cli_placeholder
OAR_FEISHU_APP_SECRET=replace_with_secret_manager_value
OAR_GRANT_KEY_ID=key-prod-v1
OAR_GRANT_KEY_HEX=64_hex_chars_for_32_byte_aes_key
